# Copie este arquivo para .env e preencha os valores

# Chave da API Anthropic (obrigatório)
ANTHROPIC_API_KEY=sua-chave-aqui

# Configurações de e-mail (opcional — remova ou deixe vazio para desativar)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app
EMAIL_FROM=Agrosintropia Monitor <seu-email@gmail.com>
EMAIL_TO=destinatario1@email.com,destinatario2@email.com
